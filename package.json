{
  "name": "@shipitandpray/pretext-table",
  "version": "1.0.0",
  "description": "Virtualized data table that auto-sizes columns and measures row heights using @chenglou/pretext — no DOM measurement, no layout shift, handles 1M+ rows.",
  "author": "ShipItAndPray",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@chenglou/pretext": ">=0.0.3",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@chenglou/pretext": "^0.0.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "jsdom": "^25.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "keywords": [
    "table",
    "data-table",
    "virtualized",
    "pretext",
    "react",
    "auto-size",
    "column-resize",
    "no-layout-shift",
    "zero-cls",
    "performance"
  ]
}
